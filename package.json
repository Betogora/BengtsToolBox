{
  "name": "bengtstoolbox",
  "private": true,
  "version": "1.0.0",
  "description": "Modularer App-Hub für Spieleabende, Gruppen und kleine Turniere.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Betogora/BengtsToolBox.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/checkBundleBudgets.mjs",
    "docs:acknowledge": "node scripts/syncSpecsFingerprint.mjs --write",
    "docs:check": "remark README.md AGENTS.md docs --frail --use remark-validate-links && node scripts/syncSpecsFingerprint.mjs --check",
    "lint": "eslint .",
    "perf:baseline:update": "node scripts/updatePerformanceBaseline.mjs",
    "perf:tournament": "node scripts/runTournamentBenchmark.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:firebase": "npx firebase-tools@15.22.1 emulators:exec --only firestore \"npm run test:firebase:rules\"",
    "test:firebase:rules": "vitest --config firebase/vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  }
}
